{
  "name": "claude-memory-harness",
  "version": "0.1.0",
  "description": "Local memory harness plugin for Claude Code with hook-based memory injection, searchable project/global memory, and automatic checkpoint writing",
  "type": "module",
  "bin": {
    "cmh": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:hooks": "node scripts/smoke-hooks.mjs",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "2": "^0.0.1-security",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "hooks/",
    "skills/",
    "scripts/",
    "README.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "keywords": [
    "claude-code",
    "plugin",
    "memory",
    "checkpoint",
    "hooks"
  ],
  "license": "MIT"
}
